{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":dependencyDashboard",
    ":semanticCommits",
    "github>DevSecNinja/.github//.renovate/autoMerge.json5",
    "github>DevSecNinja/.github//.renovate/base.json5",
    "github>DevSecNinja/.github//.renovate/customManagers.json5",
    "github>DevSecNinja/.github//.renovate/groups.json5",
    "github>DevSecNinja/.github//.renovate/labels.json5",
    "github>DevSecNinja/.github//.renovate/packageRules.json5",
    "github>DevSecNinja/.github//.renovate/semanticCommits.json5",
  ],
  // Repo-local custom manager: track the pinned pbatard/Fido dependency.
  // Fido.ps1 is NOT vendored — it is downloaded at build time from raw.githubusercontent.com
  // pinned to the exact commit recorded in the module manifest (RequiredToolingMinimums:
  // FidoTag + FidoCommit). Renovate resolves the github tag to its commit and opens a PR that
  // bumps both the tag (currentValue) and the 40-char commit SHA (currentDigest) together, so
  // the pin stays content-addressed and fully automated.
  customManagers: [
    {
      customType: "regex",
      description: "Bump pinned pbatard/Fido (tag + commit) in the module manifest",
      managerFilePatterns: ["/WindowsIsoMaker\\.psd1$/"],
      matchStrings: [
        "FidoTag\\s*=\\s*'(?<currentValue>v[0-9]+(?:\\.[0-9]+)*)'[\\s\\S]*?FidoCommit\\s*=\\s*'(?<currentDigest>[0-9a-fA-F]{40})'",
      ],
      depNameTemplate: "pbatard/Fido",
      datasourceTemplate: "github-tags",
      versioningTemplate: "semver-coerced",
    },
  ],
}
